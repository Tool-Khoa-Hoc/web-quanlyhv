# ===== Google Admin SDK (Directory API) =====
# App dùng Service Account + Domain-wide Delegation ở server để quản lý Google Groups.

# Domain Workspace mà Service Account được phép quản trị.
GOOGLE_WORKSPACE_DOMAIN=dautruonghoctap.io.vn

# Email của một SUPER ADMIN trong domain trên. Service Account sẽ "đóng vai"
# (impersonate) tài khoản này khi gọi API. BẮT BUỘC phải là super admin.
GOOGLE_ADMIN_IMPERSONATE_EMAIL=admin@dautruonghoctap.io.vn

# Service Account credentials. Dùng MỘT trong ba cách dưới đây:

# Cách A (khuyên dùng cho máy cá nhân): trỏ tới file JSON key đã tải về.
# Đường dẫn tuyệt đối, KHÔNG commit file này lên git.
GOOGLE_ADMIN_SA_KEY_FILE=E:\\Quản lý thành viên khóa học\\secrets\\service-account.json

# Cách B (khuyên dùng khi deploy): encode nguyên file JSON key sang base64 rồi dán vào secret env.
# Nếu đặt biến này thì nó được ưu tiên hơn GOOGLE_ADMIN_SA_KEY_FILE.
# GOOGLE_ADMIN_SA_KEY_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50Iiwi...

# Cách C: dán nguyên nội dung JSON key vào một dòng.
# Nếu đặt biến này thì nó được ưu tiên hơn GOOGLE_ADMIN_SA_KEY_BASE64 và GOOGLE_ADMIN_SA_KEY_FILE.
# GOOGLE_ADMIN_SA_KEY={"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@...iam.gserviceaccount.com",...}

# ===== Đăng nhập Google OAuth cho cộng tác viên (CTV) =====
# Tạo "OAuth client ID" loại Web application trong Google Cloud Console
# (APIs & Services → Credentials). Thêm Authorized redirect URI:
#   http://localhost:3000/api/auth/callback        (dev)
#   https://<domain-production>/api/auth/callback   (khi deploy)
GOOGLE_OAUTH_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=xxxxxxxx

# (Khuyên dùng khi deploy) URL gốc cố định để dựng redirect URI OAuth.
# Đặt đúng domain production để tránh lỗi redirect_uri_mismatch khi Vercel đổi URL preview.
# KHÔNG có dấu "/" ở cuối. Phải TRÙNG KHỚP với Authorized redirect URI khai trong Google Console.
#   Dev:  http://localhost:3000   (có thể bỏ trống, app tự lấy theo request)
#   Prod: https://<ten-app>.vercel.app   hoặc domain riêng
# APP_BASE_URL=https://web-quanlyhv.vercel.app

# Khóa bí mật ký session cookie. Tạo bằng:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_SESSION_SECRET=thay-bang-chuoi-ngau-nhien-dai

# (Tùy chọn) Admin bổ sung ngoài email impersonate, cách nhau bằng dấu phẩy.
# Tài khoản @<domain> không nằm trong admin sẽ chỉ dùng được quyền CTV nếu có
# trong APP_CTV_EMAILS hoặc là thành viên của CTV_ACCESS_GROUP_EMAIL.
# APP_ADMIN_EMAILS=admin2@dautruonghoctap.io.vn

# ===== Giới hạn quyền CTV =====
# Cách nhanh: tạo một Google Group chuyên cấp quyền CTV, rồi thêm/xóa CTV trong nhóm đó.
# Sau khi đặt biến này một lần, không cần sửa .env mỗi lần thêm CTV.
CTV_ACCESS_GROUP_EMAIL=ctv@dautruonghoctap.io.vn

# Cách cũ/tùy chọn: email CTV được phép đăng nhập/dùng API, cách nhau bằng dấu phẩy.
# Nếu cả APP_CTV_EMAILS và CTV_ACCESS_GROUP_EMAIL đều bỏ trống thì CTV bị chặn fail-closed.
APP_CTV_EMAILS=ctv1@dautruonghoctap.io.vn,ctv2@dautruonghoctap.io.vn

# Email nhóm "học thử" — nhóm DUY NHẤT mà CTV được phép xem & thêm thành viên (role MEMBER).
# Admin vẫn thao tác mọi nhóm và là người duy nhất được cấp/đổi role.
# BẮT BUỘC đặt nếu muốn CTV dùng được; bỏ trống thì CTV bị chặn mọi nhóm (fail-closed).
CTV_TRIAL_GROUP_EMAIL=2k9-hoc-thu@dautruonghoctap.io.vn

# ===== Kho học thử dùng chung (Vercel KV / Upstash Redis) =====
# Lưu "Khóa học thử" do CTV/admin nhập, đồng bộ giữa các thiết bị.
# Cách dùng (deploy Vercel):
#   1) Vercel → project → tab Storage → Create Database → chọn KV (Upstash Redis).
#   2) Vercel TỰ gắn các biến môi trường cho project khi deploy.
#   3) Chạy local: bấm ".env.local" / "Quickstart" trong DB đó để copy 2 biến dưới vào file này.
# Tên biến có thể là KV_REST_API_* hoặc UPSTASH_REDIS_REST_* — đặt cặp nào cũng được.
# Bỏ trống thì tính năng học thử đồng bộ tắt (app vẫn chạy bình thường).
KV_REST_API_URL=
KV_REST_API_TOKEN=
# Hoặc (tùy tích hợp Vercel cấp):
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
